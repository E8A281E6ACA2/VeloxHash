# VeloxHash HTTP API token.
# Generate a strong value with:
#   openssl rand -hex 24
VELOXHASH_API_TOKEN=change_this_to_a_long_random_token

# Public pool payout address. Do not put a private spend key or seed phrase here.
# Mining stays disabled until this is set with:
#   sudo veloxhash-mining wallet set <public-wallet-address>
VELOXHASH_WALLET_ADDRESS=
VELOXHASH_POOL_URL=auto.c3pool.org:33333
VELOXHASH_POOL_PASSWORD=x
VELOXHASH_COIN=monero
VELOXHASH_RIG_ID=

# Keep CPU mining disabled by default. The dashboard/API stays online.
# Set to 1 with: veloxhash-mining enable
VELOXHASH_MINING_ENABLED=0

# Automatic quiet policy. The dashboard/API stays online, but mining stops
# when a real user is active, during work hours, or when CPU load is high.
VELOXHASH_POLICY_ENABLED=1
VELOXHASH_POLICY_CPU_PERCENT=50
VELOXHASH_POLICY_WORK_START=08
VELOXHASH_POLICY_WORK_END=22
VELOXHASH_POLICY_LOAD_THRESHOLD=0.60
VELOXHASH_POLICY_ACTIVE_MINUTES=15

# Optional cluster monitoring. Disabled by default.
# It only reports node health to a primary registry; it does not control mining.
VELOXHASH_CLUSTER_ENABLED=0
VELOXHASH_CLUSTER_ROLE=standalone
VELOXHASH_CLUSTER_HOST=0.0.0.0
VELOXHASH_CLUSTER_PORT=8090
VELOXHASH_CLUSTER_NODE_ID=
VELOXHASH_CLUSTER_NODE_NAME=
VELOXHASH_CLUSTER_STALE_SECONDS=180
